APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=lotto
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=1440
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

# Telegram bot — register one at @BotFather (/newbot) for the Login Widget
# AND the Mini App (/newapp on the same bot). Username is set without the @.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# PCSO result scraper — pre-fills the /admin/draws/{draw}/result form.
# The on/off toggle is at /admin/settings (admin flips without a deploy);
# these only describe HOW the scraper behaves when enabled.
# Source driver: 'pcso_api' (recommended — standalone pcso-parser REST API
# with full historical coverage; pairs with the pcso_api fetcher), 'gma'
# (gmanetwork.com, plain HTTP, latest-page only — no archive), 'lottopcso'
# (legacy — blocked from PH ISPs), 'pcso_gov' (official — Akamai, needs the
# Playwright sidecar fetcher).
LOTTO_SCRAPER_SOURCE=pcso_api
LOTTO_SCRAPER_SOURCE_LABEL=pcso-parser-api
LOTTO_SCRAPER_CACHE_TTL=60
LOTTO_SCRAPER_HTTP_TIMEOUT=8

# Fetcher: 'pcso_api' (default — pairs with source=pcso_api), 'http' (plain
# Guzzle, for non-WAF HTML sources like gma/lottopcso), or 'playwright'
# (calls the standalone scraper/ Node sidecar — for pcso.gov.ph behind
# Akamai).
LOTTO_SCRAPER_FETCHER=pcso_api
LOTTO_SCRAPER_SIDECAR_URL=http://127.0.0.1:8787
LOTTO_SCRAPER_SIDECAR_TOKEN=
LOTTO_SCRAPER_SIDECAR_TIMEOUT=30

# pcso-parser API (Node REST daemon, separate repo). Set
# LOTTO_SCRAPER_SOURCE=pcso_api and LOTTO_SCRAPER_FETCHER=pcso_api to use.
# Default URL is loopback — the API should run on the same Forge box.
LOTTO_SCRAPER_API_URL=http://127.0.0.1:3001
LOTTO_SCRAPER_API_TIMEOUT=60

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
